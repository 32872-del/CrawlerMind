{
  "site": "marksandspencer.com",
  "fixture_version": "1.0",
  "extraction_mode": "browser",
  "data_source": "__NEXT_DATA__ -> serverSideGqlResponseFed.productPageData.search.results.products[]",
  "selectors": {
    "next_data": {
      "css": "script#__NEXT_DATA__",
      "post_process": "JSON parse -> props.pageProps.serverSideGqlResponseFed.productPageData.search.results",
      "description": "Next.js SSR data containing GraphQL product response"
    },
    "products": {
      "json_path": "serverSideGqlResponseFed.productPageData.search.results.products[]",
      "description": "Array of product objects from GraphQL search query"
    },
    "pagination": {
      "json_path": "serverSideGqlResponseFed.productPageData.search.results.pagination",
      "description": "Pagination metadata (limit, offset)"
    }
  },
  "field_mapping": {
    "title": "products[].title",
    "brand": "products[].brand",
    "price": "products[].price.listPrice.amount",
    "currency": "products[].price.currency",
    "product_id": "products[].id",
    "product_external_id": "products[].productExternalId",
    "seo_path": "products[].seoPath",
    "product_definition": "products[].productDefinition",
    "variant_size": "products[].variants[].size",
    "variant_sku": "products[].variants[].skuId",
    "variant_price": "products[].variants[].price",
    "image_asset_id": "products[].variants[].mediaAssets[].assetId",
    "stock_indicator": "products[].stockLevelIndicator",
    "online_only": "products[].onlineOnly"
  },
  "image_url_construction": {
    "template": "https://assets.digitalcontent.marksandspencer.app/image/upload/q_auto,f_auto/{assetId}",
    "example": "https://assets.digitalcontent.marksandspencer.app/image/upload/q_auto,f_auto/SD_01_T42_5023R_Y4_X_EC_0"
  },
  "detail_url_construction": {
    "template": "https://www.marksandspencer.com{seoPath}",
    "example": "https://www.marksandspencer.com/satin-v-neck-lace-insert-midi-slip-dress/p/clp60786172?color=BLACKMIX"
  },
  "missing_fields": {
    "description": "Often null in GraphQL response",
    "color": "Available in seoPath query param but not as standalone field"
  },
  "pagination": {
    "type": "graphql_offset",
    "params": "rows, offset via queryVariables",
    "total_items_path": "search.results.totalItems"
  }
}