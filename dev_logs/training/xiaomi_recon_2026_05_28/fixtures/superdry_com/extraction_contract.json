{
  "contract_version": "1.0",
  "site": "superdry.com",
  "source_url": "https://www.superdry.com/womens/tops",
  "source_type": "html_listing_page",
  "recommended_clm_runtime": "requests",
  "parser_strategy": {
    "name": "gtm_data_attribute_extractor",
    "description": "Extract product data from GTM data-gtm attributes on .product-tile elements. Each tile contains a JSON object with ecommerce.items[] holding product metadata.",
    "input": "HTML string of listing page",
    "entry_selector": ".product-tile[data-gtm]",
    "attribute": "data-gtm",
    "decode_steps": [
      "Find all elements matching .product-tile[data-gtm]",
      "Read data-gtm attribute value",
      "HTML entity decode: &quot; -> \", &amp; -> &",
      "JSON parse the decoded string",
      "Extract ecommerce.items[0] from parsed object"
    ],
    "fallback_selectors": {
      "product_id": ".tile-image-wrapper-link[data-product-id] -> data-product-id",
      "image": "img.tile-image[srcset] -> parse srcset, take largest",
      "detail_url": ".tile-image-wrapper-link[href] -> href"
    }
  },
  "pagination_strategy": {
    "type": "demandware_query_params",
    "url_template": "{category_url}?start={offset}&sz={page_size}",
    "default_page_size": 48,
    "offset_calculation": "page_index * page_size",
    "notes": "Demandware standard pagination. start=0 for first page."
  },
  "field_paths": {
    "title": {
      "path": "ecommerce.items[0].item_name",
      "type": "string",
      "required": true
    },
    "highest_price": {
      "path": "ecommerce.items[0].price",
      "type": "number",
      "required": true,
      "notes": "Also available: item_orig_price for original price before discount"
    },
    "currency": {
      "path": "Hardcoded GBP for .com domain",
      "type": "string",
      "required": true
    },
    "color": {
      "path": "ecommerce.items[0].item_colour",
      "type": "string",
      "required": false
    },
    "size": {
      "path": null,
      "type": "null",
      "required": false,
      "missing_reason": "Sizes only available on product detail pages"
    },
    "description": {
      "path": null,
      "type": "null",
      "required": false,
      "missing_reason": "Descriptions only available on product detail pages"
    },
    "image_url": {
      "path": "img.tile-image[srcset] (parse srcset, take largest width)",
      "type": "string",
      "required": true,
      "notes": "Not in GTM JSON. Must extract from sibling HTML element."
    },
    "product_url": {
      "path": ".tile-image-wrapper-link[href]",
      "type": "string",
      "required": true,
      "notes": "Relative path, needs base URL prepend: https://www.superdry.com"
    },
    "category_level_1": {
      "path": "ecommerce.items[0].item_category",
      "type": "string",
      "required": true
    },
    "category_level_2": {
      "path": "ecommerce.items[0].item_category2",
      "type": "string",
      "required": false
    },
    "brand": {
      "path": "ecommerce.items[0].item_brand",
      "type": "string",
      "required": true
    },
    "sku": {
      "path": "ecommerce.items[0].item_sku",
      "type": "string",
      "required": true
    },
    "season": {
      "path": "ecommerce.items[0].item_season",
      "type": "string",
      "required": false
    },
    "original_price": {
      "path": "ecommerce.items[0].item_orig_price",
      "type": "number",
      "required": false
    }
  },
  "post_processors": [
    {
      "field": "data-gtm",
      "operation": "html_entity_decode",
      "params": {
        "entities": {
          "&quot;": "\"",
          "&amp;": "&"
        }
      }
    },
    {
      "field": "data-gtm",
      "operation": "json_parse",
      "params": {}
    },
    {
      "field": "image_url",
      "operation": "parse_srcset",
      "params": {
        "strategy": "largest_width"
      }
    },
    {
      "field": "product_url",
      "operation": "prepend_base",
      "params": {
        "base_url": "https://www.superdry.com"
      }
    }
  ],
  "missing_fields": [
    "size",
    "description"
  ],
  "evidence_files": [
    "raw_evidence_list_page.html",
    "raw_evidence_gtm_sample.json"
  ],
  "confidence": 0.85,
  "implementation_notes": "Superdry is the simplest extractor. requests mode works. GTM data-gtm is highly reliable. Only size/description need detail page fetch."
}