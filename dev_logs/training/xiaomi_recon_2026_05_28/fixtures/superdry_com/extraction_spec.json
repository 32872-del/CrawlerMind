{
  "site": "superdry.com",
  "fixture_version": "1.0",
  "extraction_mode": "requests",
  "data_source": "GTM data-gtm attribute on .product-tile elements",
  "selectors": {
    "product_tile": {
      "css": ".product-tile",
      "description": "Each product tile div with data-gtm attribute"
    },
    "gtm_json": {
      "css": ".product-tile[data-gtm]",
      "attribute": "data-gtm",
      "post_process": "HTML entity decode + JSON parse -> ecommerce.items[0]",
      "description": "GTM JSON embedded in data-gtm attribute"
    },
    "detail_link": {
      "css": ".tile-image-wrapper-link[href]",
      "attribute": "href",
      "description": "Product detail page URL"
    },
    "product_id": {
      "css": ".tile-image-wrapper-link[data-product-id]",
      "attribute": "data-product-id",
      "description": "Numeric product ID"
    },
    "image": {
      "css": "img.tile-image[srcset]",
      "attribute": "srcset",
      "post_process": "Parse srcset, take largest URL",
      "description": "Product image URL from CDN"
    }
  },
  "field_mapping": {
    "title": "gtm.ecommerce.items[0].item_name",
    "price": "gtm.ecommerce.items[0].price",
    "currency": "gtm.ecommerce.items[0].currency (default GBP)",
    "color": "gtm.ecommerce.items[0].item_colour",
    "brand": "gtm.ecommerce.items[0].item_brand",
    "category_l1": "gtm.ecommerce.items[0].item_category",
    "category_l2": "gtm.ecommerce.items[0].item_category2",
    "sku": "gtm.ecommerce.items[0].item_sku",
    "season": "gtm.ecommerce.items[0].item_season",
    "original_price": "gtm.ecommerce.items[0].item_orig_price",
    "image": "img.tile-image srcset (largest)",
    "detail_url": ".tile-image-wrapper-link href",
    "product_id": ".tile-image-wrapper-link data-product-id"
  },
  "missing_fields": {
    "size": "Not available in listing page - detail page only",
    "description": "Not available in listing page - detail page only"
  },
  "pagination": {
    "type": "demandware_cgsize",
    "url_pattern": "{category_url}?start={offset}&sz={page_size}",
    "default_page_size": 48
  }
}